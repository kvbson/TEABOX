{
  "name": "teabox",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:client": "vite",
    "dev:server": "nodemon --watch api -e ts --exec \"npx tsx api/server/server.ts\"",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.node.json",
    "lint": "eslint --ext [.ts,.tsx] ./src --cache --cache-location ./dist",
    "preview": "vite preview",
    "typecheck": "npx tsc --noEmit --watch --project tsconfig.app.json --preserveWatchOutput",
    "dev": "concurrently -n CLIENT,SERVER,TYPECHECK -c purple,green,blue \"vite\" \"npm run dev:server\" \"npm run typecheck\"",
    "build": "npm run build:client && npm run build:server",
    "start": "node dist/api/server/server.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.5",
    "@mui/material": "^7.3.5",
    "axios": "^1.10.0",
    "bcrypt": "^6.0.0",
    "blurhash": "^2.0.5",
    "cors": "^2.8.5",
    "dompurify": "^3.2.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "mkcert": "^3.2.0",
    "mongoose": "^8.13.0",
    "mysql2": "^3.15.3",
    "react": "^19.0.0",
    "react-blurhash": "^0.3.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.5.0",
    "react-toastify": "^11.0.5",
    "recharts": "^2.15.3",
    "sanitize-html": "^2.17.0",
    "sharp": "^0.34.2",
    "swapy": "^1.0.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/sanitize-html": "^2.16.0",
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "nodemon": "^3.1.9",
    "puppeteer": "^24.10.1",
    "sanitize-html": "^2.17.0",
    "tsx": "^4.19.3",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.2.0"
  }
}
