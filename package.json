{
  "name": "teabox",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "imports": {
    "#api/*": "./api/*.js",
    "#db/*": "./api/db/*.js",
    "#server/*": "./api/server/*.js",
    "#types/*": "./api/types/*.js"
  },
  "scripts": {
    "dev:client": "vite",
    "dev:server": "nodemon --watch api/server -e ts --exec \"npx tsx api/server/server.ts\"",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.node.json",
    "build": "npm run build:client && npm run build:server",
    "lint": "eslint --ext [.ts,.tsx] ./src --cache --cache-location ./dist",
    "preview": "vite preview",
    "dev": "concurrently -n CLIENT,SERVER \"vite\" \"npm run dev:server\"",
    "postinstall": "npx tsx ./api/certs/run.ts && npm run build"
  },
  "dependencies": {
    "bottleneck": "^2.19.5",
    "mongoose": "^8.13.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.5.0",
    "react-toastify": "^11.0.5",
    "swapy": "^1.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "@vitejs/plugin-react": "^4.3.4",
    "axios": "^1.8.2",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "express": "^4.21.2",
    "globals": "^15.15.0",
    "helmet": "^8.0.0",
    "mkcert": "^3.2.0",
    "nodemon": "^3.1.9",
    "puppeteer": "^24.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.2.0"
  }
}
