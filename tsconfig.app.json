{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "./src",
    "vite-env.d.ts",
    "vite.config.ts"
  ],
  "exclude": [
    "node_modules",
    "api",
    "dist"
  ]
}