{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./build",
    "rootDir": "./api",
    "baseUrl": ".",
    "types": ["node"]
  },
  "include": ["./api/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
